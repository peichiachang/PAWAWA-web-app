# Copy this file to .env and fill in your own values.

PORT=8080
HOST=0.0.0.0

# mock | gemini
AI_PROVIDER=gemini

GEMINI_API_KEY=replace_with_your_real_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_TO_MOCK=true

# Weather-based evaporation correction (Open-Meteo)
WEATHER_LAT=25.0330
WEATHER_LON=121.5654
WATER_SURFACE_CM2=120
DEFAULT_TEMP_C=25
DEFAULT_HUMIDITY_PCT=60

# App 端 AI 模式：mock | http | gemini（原生版 production 建議 http，金鑰不進 App）
EXPO_PUBLIC_AI_SERVICE_MODE=gemini

# 原生版（iOS/Android）必填：後端 API 基底 URL（結尾勿加 /api，例：https://your-api.example.com）
# EXPO_PUBLIC_API_BASE_URL=
